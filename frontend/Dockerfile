# Stage 1: Base - Install dependencies
FROM oven/bun:1 AS base
WORKDIR /app

# Copy dependency files
COPY package.json bun.lock ./

# Install dependencies (including devDependencies for building)
RUN bun install --frozen-lockfile

# Stage 2: Builder - Build the application
FROM base AS builder
WORKDIR /app
COPY . .

# NEXT_PUBLIC_* values are compiled into client bundles by Next.js.
ARG NEXT_PUBLIC_USE_SAML_LOGIN=false
ARG NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
ENV NEXT_PUBLIC_USE_SAML_LOGIN=$NEXT_PUBLIC_USE_SAML_LOGIN
ENV NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL

# Build the application
RUN bun run build

# Stage 3: Runner - Production image
# We use a fresh, clean image to discard all build tools and caches
FROM oven/bun:1-slim AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ARG NEXT_PUBLIC_USE_SAML_LOGIN=false
ARG NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
ENV NEXT_PUBLIC_USE_SAML_LOGIN=$NEXT_PUBLIC_USE_SAML_LOGIN
ENV NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL

# Copy only the public assets
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
# Copy the standalone server generated by Next.js


EXPOSE 3000

# Standalone mode creates a server.js file
CMD ["bun", "server.js"]
