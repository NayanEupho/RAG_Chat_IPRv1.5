# RAG Chat IPR - Configuration File

# ===========================================
# 0. Authentication Mode
USE_SAML_LOGIN=false
# ===========================================

# ===========================================
# 1. Main Chat Model (Inference)
# ===========================================
RAG_MAIN_HOST="http://10.20.20.90:4000/v1"
RAG_MAIN_MODEL="qwen2.5-7b"
RAG_MAIN_ENGINE="litellm"
# Empty for Ollama. Required for LiteLLM/OpenAI-compatible endpoints.
RAG_MAIN_API_KEY=""

# Optional separate model for ingestion LLM markdown normalization.
# If omitted, normalization falls back to RAG_MAIN_HOST/RAG_MAIN_MODEL.
RAG_NORMALIZATION_HOST="http://10.20.20.90:4000/v1"
RAG_NORMALIZATION_MODEL="qwen2.5-7b"
RAG_NORMALIZATION_ENGINE="litellm"
# Empty for Ollama. Required for LiteLLM/OpenAI-compatible endpoints.
RAG_NORMALIZATION_API_KEY=""

# ===========================================
# 2. RAG Embedding Model (Vectorization)
# ===========================================
RAG_EMBED_HOST="http://10.20.39.12:11438"
RAG_EMBED_MODEL="embeddinggemma:300m"
RAG_EMBED_ENGINE="ollama"
# Empty for Ollama. Required only if embeddings are served through LiteLLM/OpenAI-compatible API.
RAG_EMBED_API_KEY=""


# ===========================================
# LiteLLM/vLLM Example (copy into private .env only when switching runtime)
# ===========================================
# IMPORTANT: Do not commit real LiteLLM keys. Paste the real key only in .env.
#
# RAG_MAIN_HOST="http://10.20.20.90:4000/v1"
# RAG_MAIN_MODEL="qwen2.5-7b"
# RAG_MAIN_ENGINE="litellm"
# RAG_MAIN_API_KEY=""
#
# RAG_NORMALIZATION_HOST="http://10.20.20.90:4000/v1"
# RAG_NORMALIZATION_MODEL="qwen2.5-7b"
# RAG_NORMALIZATION_ENGINE="litellm"
# RAG_NORMALIZATION_API_KEY=""
#
# Recommended initial rollout: keep embeddings on Ollama to preserve Chroma vector compatibility.
# Only switch RAG_EMBED_ENGINE to litellm after /v1/embeddings is verified and documents are re-indexed if needed.

# ===========================================
# 3. RAG Workflow Strategy
# ===========================================
# Options: "fused" (72B+, Fast, One-Shot) or "modular" (7B+, Stable, Sequential)
RAG_WORKFLOW="fused"

# ===========================================
# 3B. RAG Tuning Options
# ===========================================
# Final top-k chunks passed to the generator (higher = better recall, moderate TTFT impact)
RAG_RETRIEVAL_TOP_K=5
# Minimum reranker score to keep a chunk (filter out noise while preserving relevant Q&A fragments)
RAG_RETRIEVAL_MIN_SCORE=0.02
# Parsing strategy to use: "auto", "pymupdf4llm", "docling_vision", or "vision_llm"
RAG_PARSING_MODE=vision_llm
# Initial candidate pool per query before reranker pruning (n_results per chroma query)
RAG_CANDIDATE_MULTIPLIER=7
# Experimental: compact RAG session memory. Current benchmark verdict: keep false by default.
# false preserves the latency-safe legacy prompt path for both Ollama and vLLM/LiteLLM.
RAG_SESSION_MEMORY_ENABLED=false

# HNSW Index Tuning (construction params only apply on fresh rebuild; search_ef is immediate)
HNSW_EF_SEARCH=32
HNSW_EF_CONSTRUCTION=200
HNSW_M=16

# ===========================================
# Model Context Window (in tokens)
# ===========================================
# MODEL_CONTEXT_WINDOW is the real context budget used by application code.
# It controls how much total context the RAG agent is allowed to build: history,
# retrieved document chunks, fixed prompt text, and output reserve are budgeted from this value.
# Ollama: this value is also sent as num_ctx when the chat model is created. If Ollama
# has the model loaded with a different context, Ollama may reload/reconfigure that model.
# vLLM/LiteLLM/OpenAI-compatible: this value only controls the app-side RAG budget;
# it does not resize vLLM. The vLLM server-side limit is set by --max-model-len, and
# MODEL_CONTEXT_WINDOW must stay <= that served limit.
MODEL_CONTEXT_WINDOW=16384
# Set RAG_NO_THINKING=true to force-disable reasoning for thinking Ollama models (overrides auto-detect).
# For vLLM, use non-thinking served models for now; thinking-mode control is provider/model specific.
RAG_NO_THINKING=true

# ===========================================
# 4. VLM OCR Options
# ===========================================
RAG_VLM_HOST="http://10.20.39.12:11438"
RAG_VLM_MODEL="qwen3.6:35b-a3b-q8_0"
RAG_VLM_ENGINE="ollama"
# Empty for Ollama. Required only if VLM is served through LiteLLM/OpenAI-compatible API.
RAG_VLM_API_KEY=""
RAG_VLM_PROMPT="auto"
RAG_VLM_DPI=220
RAG_VLM_TIMEOUT_SECONDS=300
RAG_VLM_CONCURRENCY=1
RAG_VLM_RETRIES=1

# ===========================================
# 5. System Options
# ===========================================
ANONYMIZED_TELEMETRY=False
INGEST_FORCE_CPU=True

# ===========================================
# SAML SSO Configuration
# ===========================================


SAML_IDP_ENTITY_ID="https://adfs.ipr.res.in/adfs/services/trust"
SAML_IDP_SSO_URL="https://adfs.ipr.res.in/adfs/ls"
SAML_IDP_SLO_URL="https://adfs.ipr.res.in/adfs/ls/?wa=wsignout1.0"
SAML_IDP_CERT_FILE="idp.crt"

SAML_SP_ENTITY_ID="https://askme.ipr.res.in/metadata"
SAML_SP_ACS_URL="https://askme.ipr.res.in/saml/acs"
SAML_SP_SLO_URL="https://askme.ipr.res.in/saml/slo"
#SAML_SP_ENTITY_ID="http://10.20.30.4:8000/metadata"
#SAML_SP_ACS_URL="http://10.20.30.4:8000/saml/acs"
#SAML_SP_SLO_URL="http://10.20.30.4:8000/saml/slo"

# Session Security
SAML_SESSION_SECRET="<generate-a-long-random-secret>"
SAML_SESSION_MAX_AGE=28800
# Set to "false" only for localhost SAML testing (defaults to "true" for HTTPS/production)
SAML_COOKIE_SECURE=true
# Windows local dev: explicit pysaml2 XML signature helper.
# Production Docker discovers xmlsec1 from PATH.
XMLSEC_BINARY=C:\msys64\ucrt64\bin\xmlsec1.exe

# ===========================================
# SAML SP Certificate Configuration
# ===========================================
SAML_SP_CERT_FILE="C:\Users\Nayan\Desktop\RAG_Chat_IPRv1.5\askme.crt"
SAML_SP_KEY_FILE="C:\Users\Nayan\Desktop\RAG_Chat_IPRv1.5\askme.key"
